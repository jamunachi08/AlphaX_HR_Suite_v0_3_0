{
  "doctype": "DocType",
  "name": "HR EOSB Provision Log",
  "module": "AlphaX HR Leave Payroll",
  "custom": 0,
  "is_submittable": 0,
  "track_changes": 0,
  "autoname": "format:EOSBLOG-.YYYY.MM.-.#####",
  "description": "Monthly EOSB liability snapshot for all active employees. Created by scheduled task and on EOSB Settlement submit.",
  "fields": [
    {
      "fieldname": "employee",
      "fieldtype": "Link",
      "label": "Employee",
      "options": "Employee",
      "reqd": 1,
      "in_list_view": 1,
      "search_index": 1
    },
    {
      "fieldname": "company",
      "fieldtype": "Link",
      "label": "Company",
      "options": "Company",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "month_key",
      "fieldtype": "Data",
      "label": "Month (YYYY-MM)",
      "reqd": 1,
      "in_list_view": 1,
      "description": "Format: YYYY-MM — used as idempotency key for monthly snapshots."
    },
    {
      "fieldname": "snapshot_date",
      "fieldtype": "Date",
      "label": "Snapshot Date",
      "reqd": 1
    },
    {
      "fieldname": "service_years",
      "fieldtype": "Float",
      "label": "Service Years",
      "precision": "4",
      "read_only": 1
    },
    {
      "fieldname": "eosb_amount",
      "fieldtype": "Currency",
      "label": "EOSB Amount",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "base_salary_used",
      "fieldtype": "Currency",
      "label": "Base Salary Used",
      "read_only": 1
    },
    {
      "fieldname": "leave_entitlement_days",
      "fieldtype": "Float",
      "label": "Leave Entitlement Days",
      "precision": "2",
      "read_only": 1
    },
    {
      "fieldname": "benefit_profile",
      "fieldtype": "Data",
      "label": "Benefit Profile",
      "read_only": 1
    },
    {
      "fieldname": "policy_source",
      "fieldtype": "Data",
      "label": "Policy Source",
      "read_only": 1
    },
    {
      "fieldname": "settlement_reference",
      "fieldtype": "Link",
      "label": "Settlement Reference",
      "options": "EOSB Settlement",
      "description": "Populated when this log was created from an EOSB Settlement submission."
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1
    },
    {
      "role": "HR Manager",
      "read": 1, "write": 1, "create": 1
    },
    {
      "role": "HR User",
      "read": 1
    }
  ]
}
